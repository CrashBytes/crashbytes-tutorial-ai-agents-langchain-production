# =============================================================================
# AI Agent Configuration - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# LLM API Keys
# =============================================================================
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Anthropic Claude API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# LLM Configuration
# =============================================================================
# Default model to use (gpt-4-turbo-preview, gpt-4, claude-3-opus-20240229, etc.)
DEFAULT_MODEL=gpt-4-turbo-preview

# Temperature for LLM responses (0.0-2.0, higher = more creative)
LLM_TEMPERATURE=0.7

# Maximum tokens for LLM responses
LLM_MAX_TOKENS=2000

# =============================================================================
# Redis Configuration (Short-term Memory & Caching)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Memory TTL in seconds (1 hour = 3600)
MEMORY_TTL_SECONDS=3600

# =============================================================================
# PostgreSQL Configuration (Long-term Memory & Audit)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=your_secure_password_here

# Connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Full PostgreSQL connection URL (alternative to individual settings)
# DATABASE_URL=postgresql://agent_user:your_password@localhost:5432/agent_db

# =============================================================================
# Agent Behavior
# =============================================================================
# Maximum iterations for agent execution
AGENT_MAX_ITERATIONS=10

# Timeout for agent execution (seconds)
AGENT_TIMEOUT_SECONDS=60

# Enable tool validation before execution
ENABLE_TOOL_VALIDATION=true

# Maximum history messages to keep in memory
MAX_HISTORY_MESSAGES=20

# =============================================================================
# Tool Configuration
# =============================================================================
# Web search tool settings
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=10

# Weather API key (example tool - get from https://openweathermap.org/api)
WEATHER_API_KEY=your_weather_api_key_here

# =============================================================================
# API Server Configuration
# =============================================================================
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Enable CORS (for development)
ENABLE_CORS=true

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Enable OpenTelemetry tracing
ENABLE_TRACING=true

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json or text)
LOG_FORMAT=json

# OpenTelemetry OTLP endpoint (optional - for sending traces)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name for tracing
SERVICE_NAME=ai-agent

# =============================================================================
# Security
# =============================================================================
# API key for authentication (optional - implement in middleware)
API_KEY=your_api_key_here

# JWT secret for token-based auth (if implementing)
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# Feature Flags
# =============================================================================
# Enable experimental features
ENABLE_STREAMING=false
ENABLE_MULTI_AGENT=false
ENABLE_HUMAN_IN_LOOP=false

# =============================================================================
# Development Settings
# =============================================================================
# Enable debug mode (more verbose logging)
DEBUG=false

# Reload API server on code changes
AUTO_RELOAD=true

# =============================================================================
# Production Settings
# =============================================================================
# Environment (development, staging, production)
ENVIRONMENT=development

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# =============================================================================
# Kubernetes/Cloud Configuration
# =============================================================================
# These are typically set by Kubernetes Secrets or cloud provider
# KUBERNETES_NAMESPACE=ai-agents
# KUBERNETES_POD_NAME=ai-agent-xxxxx
# KUBERNETES_NODE_NAME=node-1
